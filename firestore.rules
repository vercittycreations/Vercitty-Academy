rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create: if isAdmin();
      allow update: if isLoggedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /userCourses/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
    }

    match /progress/{docId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isLoggedIn() && resource.data.userId == request.auth.uid;
    }

    match /bookmarks/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /notes/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /lastLesson/{docId} {
      allow read, write: if isLoggedIn();
    }

    match /quizQuestions/{lessonId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /questionBank/{questionId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /quizResults/{docId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Login history — user writes own, admin reads all
    match /loginHistory/{docId} {
      allow read: if isLoggedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    // Course feedback — user writes own, all can read ratings
    match /courseFeedback/{docId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isLoggedIn() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ==========================================
    // NAYE RULES AAKE ERRORS FIX KARNE KE LIYE
    // ==========================================

    // Announcements: Admin manage karega, students read karenge
    match /announcements/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Batches: Admin manage karega, students read karenge
    match /batches/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Batch Members: Admin assign karega
    match /batchMembers/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Submissions: Students apne assignments submit karenge, Admin sab dekh/grade kar sakta hai
    match /submissions/{docId} {
      // User sirf apni submission dekh sakta hai, Admin sabki
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // User sirf apne ID se create kar sakta hai
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      // User edit kar sakta hai (agar allow karna ho), Admin grade update kar sakta hai
      allow update: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Reading Modules: Admin manage karega
    match /readingModules/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
  }
}